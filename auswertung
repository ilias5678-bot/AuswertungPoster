<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>DGfB 2026 Admin Dashboard</title>
    <script src="https://www.gstatic.com/firebasejs/9.1.3/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.1.3/firebase-database-compat.js"></script>
    <style>
        body { font-family: sans-serif; padding: 20px; background: #f4f7f6; color: #333; }
        .container { max-width: 1000px; margin: 0 auto; background: white; padding: 30px; border-radius: 12px; shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 12px; border: 1px solid #ddd; text-align: left; }
        th { background: #f8f9fa; cursor: pointer; }
        tr:nth-child(even) { background: #f2f2f2; }
        .stats-box { display: flex; gap: 20px; margin-bottom: 20px; }
        .stat-card { background: #3498db; color: white; padding: 15px; border-radius: 8px; flex: 1; text-align: center; }
        .btn-export { background: #2ecc71; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-weight: bold; }
        .btn-refresh { background: #3498db; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>

<div class="container">
    <h1>📊 Poster Competition - Auswertung</h1>
    
    <div class="stats-box">
        <div class="stat-card"><h3 id="countJuroren">0</h3><p>Juroren gesamt</p></div>
        <div class="stat-card"><h3 id="countVotes">0</h3><p>Bewertungen abgegeben</p></div>
    </div>

    <button class="btn-refresh" onclick="fetchData()">🔄 Daten aktualisieren</button>
    <button class="btn-export" onclick="exportCSV()">📥 CSV Export (Excel)</button>

    <table id="resultTable">
        <thead>
            <tr>
                <th>Poster ID</th>
                <th>Durchschnitt Score</th>
                <th>Anzahl Wertungen</th>
                <th>Details (Rohdaten)</th>
            </tr>
        </thead>
        <tbody id="tableBody">
            </tbody>
    </table>
</div>

<script>
    // BITTE HIER DEINE CONFIG EINTRAGEN (WIE IM JURY PANEL)
    const firebaseConfig = {
        apiKey: "DEIN_API_KEY",
        authDomain: "dgfb-2026.firebaseapp.com",
        databaseURL: "https://dgfb-2026-default-rtdb.europe-west1.firebasedatabase.app",
        projectId: "dgfb-2026"
    };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();

    let globalData = [];

    async function fetchData() {
        const snapshot = await db.ref('results').once('value');
        const results = snapshot.val();
        if (!results) return alert("Noch keine Daten vorhanden.");

        const posterAggregation = {};
        let jurorCount = 0;
        let totalVotes = 0;

        for (let jID in results) {
            jurorCount++;
            const ratings = results[jID].ratings;
            for (let pIdx in ratings) {
                totalVotes++;
                // Wir nutzen hier die Index-Logik aus deinem Jury-Code
                if (!posterAggregation[pIdx]) posterAggregation[pIdx] = { sum: 0, count: 0 };
                
                let posterScore = 0;
                let critCount = 0;
                for (let cIdx in ratings[pIdx]) {
                    posterScore += parseInt(ratings[pIdx][cIdx]);
                    critCount++;
                }
                posterAggregation[pIdx].sum += (posterScore / critCount);
                posterAggregation[pIdx].count += 1;
            }
        }

        document.getElementById('countJuroren').innerText = jurorCount;
        document.getElementById('countVotes').innerText = totalVotes;

        renderTable(posterAggregation);
    }

    function renderTable(agg) {
        const body = document.getElementById('tableBody');
        body.innerHTML = "";
        globalData = [];

        // Sortieren nach Score (Absteigend)
        const sorted = Object.keys(agg).sort((a, b) => (agg[b].sum / agg[b].count) - (agg[a].sum / agg[a].count));

        sorted.forEach(pKey => {
            const avg = (agg[pKey].sum / agg[pKey].count).toFixed(2);
            globalData.push({ id: pKey, score: avg, count: agg[pKey].count });
            
            const row = `<tr>
                <td><strong>${pKey}</strong></td>
                <td><b style="color:#e67e22">${avg}</b> / 5.00</td>
                <td>${agg[pKey].count}</td>
                <td>Berechnet aus allen Kriterien</td>
            </tr>`;
            body.innerHTML += row;
        });
    }

    function exportCSV() {
        let csv = "PosterID;Durchschnittscore;Anzahl_Wertungen\n";
        globalData.forEach(row => {
            csv += `${row.id};${row.score};${row.count}\n`;
        });
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement("a");
        link.href = URL.createObjectURL(blob);
        link.setAttribute("download", "DGfB_Poster_Results.csv");
        link.click();
    }

    window.onload = fetchData;
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DGfB 2026 - Admin Auswertung</title>
    <script src="https://www.gstatic.com/firebasejs/9.1.3/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.1.3/firebase-database-compat.js"></script>
    <style>
        :root { --primary: #2c3e50; --accent: #3498db; --success: #2ecc71; --bg: #f4f7f6; }
        body { font-family: -apple-system, sans-serif; background: var(--bg); margin: 0; padding: 20px; color: #333; }
        .container { max-width: 1100px; margin: 0 auto; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.1); }
        h1 { color: var(--primary); border-bottom: 3px solid var(--accent); padding-bottom: 10px; margin-top: 0; }
        
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px; }
        .stat-card { background: var(--primary); color: white; padding: 20px; border-radius: 10px; text-align: center; }
        .stat-card h3 { margin: 0; font-size: 2rem; color: var(--accent); }

        table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 0.9rem; }
        th, td { padding: 12px; border: 1px solid #eee; text-align: left; }
        th { background: #f8f9fa; color: var(--primary); text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; }
        tr:hover { background: #fdfdfd; }
        .rank-1 { background: #fff9c4 !important; font-weight: bold; }
        
        .controls { margin-bottom: 20px; display: flex; gap: 10px; }
        button { padding: 12px 20px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.2s; }
        .btn-refresh { background: var(--accent); color: white; }
        .btn-csv { background: var(--success); color: white; }
        button:active { transform: scale(0.98); }

        .juror-tag { display: inline-block; background: #e0e0e0; padding: 4px 10px; border-radius: 15px; margin: 3px; font-size: 0.75rem; }
    </style>
</head>
<body>

<div class="container">
    <h1>📊 DGfB 2026 Poster-Ranking</h1>

    <div class="stats-grid">
        <div class="stat-card"><h3 id="stat-juroren">0</h3><p>Aktive Juroren</p></div>
        <div class="stat-card"><h3 id="stat-poster">0</h3><p>Bewertete Poster</p></div>
        <div class="stat-card"><h3 id="stat-top"> - </h3><p>Aktueller Spitzenreiter</p></div>
    </div>

    <div class="controls">
        <button class="btn-refresh" onclick="loadFirebaseData()">🔄 Daten aktualisieren</button>
        <button class="btn-csv" onclick="downloadCSV()">📥 CSV Export</button>
    </div>

    <div id="jurorList" style="margin-bottom: 20px;">
        <small>Eingegangene Daten von: </small><span id="names-container"></span>
    </div>

    <table>
        <thead>
            <tr>
                <th>Rang</th>
                <th>ID</th>
                <th>Titel / Erstautor</th>
                <th>Ø Score (1-5)</th>
                <th>Anzahl Juroren</th>
            </tr>
        </thead>
        <tbody id="ranking-body">
            <tr><td colspan="5" style="text-align:center;">Lade Daten...</td></tr>
        </tbody>
    </table>
</div>

<script>
    // Konfiguration (Gleich wie in deinem Jury-Panel)
    const firebaseConfig = {
        apiKey: "AIzaSyAMk8sqJiTbOB1LKNZJ4peKEBoyz_2sohM",
        authDomain: "dgfb-2026.firebaseapp.com",
        databaseURL: "https://dgfb-2026-default-rtdb.europe-west1.firebasedatabase.app",
        projectId: "dgfb-2026"
    };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();

    // Mapping-Daten (Um IDs in Namen aufzulösen)
    const posterMapping = {
        111: "Ronzon et al.", 146: "Greiner-Perth et al.", 155: "Knottnerus-Meyer et al.",
        158: "Reisinger et al.", 168: "Komrakova et al.", 170: "Catalano et al.",
        172: "Grummüller et al.", 188: "Osterloh et al.", 204: "Erhard et al.",
        223: "Lieshoff et al.", 224: "Buchholz et al.", 229: "Rudek et al.",
        251: "Sadretdinova et al.", 259: "Kelley et al.", 264: "Oestreich et al."
    };

    let processedRanking = [];

    async function loadFirebaseData() {
        try {
            const snapshot = await db.ref('results').once('value');
            const allResults = snapshot.val();
            if (!allResults) {
                alert("Noch keine Daten in Firebase vorhanden.");
                return;
            }

            const aggregation = {};
            const jurorNames = [];

            // 1. Daten durchlaufen und summieren
            Object.values(allResults).forEach(entry => {
                jurorNames.push(entry.juror_name || "Anonym");
                
                const ratings = entry.ratings;
                for (let pIdx in ratings) {
                    // Wir nutzen die Poster-ID als Key (pIdx entspricht im alten Code dem Index 0-14)
                    // Um sicherzugehen, ziehen wir die ID aus dem Mapping oder nutzen den Index
                    const pID = Object.keys(posterMapping)[pIdx] || pIdx;

                    if (!aggregation[pID]) {
                        aggregation[pID] = { sumScores: 0, countJurors: 0 };
                    }

                    // Durchschnitt des einzelnen Posters bei diesem einen Juror (über die 3 Kriterien)
                    const criteriaScores = Object.values(ratings[pIdx]);
                    const jurorAvgForThisPoster = criteriaScores.reduce((a,b) => a + parseInt(b), 0) / criteriaScores.length;

                    aggregation[pID].sumScores += jurorAvgForThisPoster;
                    aggregation[pID].countJurors += 1;
                }
            });

            // 2. In Array umwandeln und finalen Durchschnitt berechnen
            processedRanking = Object.keys(aggregation).map(id => {
                return {
                    id: id,
                    name: posterMapping[id] || "Unbekannt",
                    finalAvg: (aggregation[id].sumScores / aggregation[id].countJurors).toFixed(2),
                    voters: aggregation[id].countJurors
                };
            });

            // 3. Sortieren (Beste zuerst)
            processedRanking.sort((a, b) => b.finalAvg - a.finalAvg);

            renderUI(jurorNames);
        } catch (e) {
            console.error(e);
            alert("Fehler beim Laden: " + e.message);
        }
    }

    function renderUI(names) {
        // Stats
        document.getElementById('stat-juroren').innerText = names.length;
        document.getElementById('stat-poster').innerText = processedRanking.length;
        document.getElementById('stat-top').innerText = processedRanking.length > 0 ? "ID " + processedRanking[0].id : "-";

        // Namen Tags
        const nameCont = document.getElementById('names-container');
        nameCont.innerHTML = names.map(n => `<span class="juror-tag">${n}</span>`).join('');

        // Tabelle
        const body = document.getElementById('ranking-body');
        body.innerHTML = processedRanking.map((p, index) => `
            <tr class="${index === 0 ? 'rank-1' : ''}">
                <td>${index + 1}</td>
                <td><b>${p.id}</b></td>
                <td>${p.name}</td>
                <td><span style="color:var(--accent); font-weight:bold;">${p.finalAvg}</span></td>
                <td>${p.voters}</td>
            </tr>
        `).join('');
    }

    function downloadCSV() {
        if (processedRanking.length === 0) return;
        let csv = "Rang;PosterID;Autor;Durchschnittsscore;AnzahlJuroren\n";
        processedRanking.forEach((p, i) => {
            csv += `${i+1};${p.id};${p.name};${p.finalAvg};${p.voters}\n`;
        });
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement("a");
        link.href = URL.createObjectURL(blob);
        link.download = `DGfB_2026_Ranking_${new Date().toLocaleTimeString()}.csv`;
        link.click();
    }

    // Beim Start laden
    window.onload = loadFirebaseData;
</script>

</body>
</html>
